<policies>
  <inbound>
    <base />
    <rate-limit-by-key calls="60" renewal-period="60" counter-key="@(context.Subscription?.Id ?? context.Request.IpAddress)" />
    <!-- ip-filter intentionally omitted for the public sandbox; add an <ip-filter action="allow"> with your CIDRs once APIM is VNet-integrated -->
  </inbound>
  <backend><base /></backend>
  <outbound><base /></outbound>
  <on-error><base /></on-error>
</policies>
