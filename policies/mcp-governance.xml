<policies>
  <inbound>
    <base />
    <rate-limit-by-key calls="60" renewal-period="60" counter-key="@(context.Subscription?.Id ?? context.Request.IpAddress)" />
    <!--
      EXAMPLE internal CIDR. The 10.0.0.0/8 range below is illustrative only.
      Parameterize this (e.g. via an `allowed_cidr` variable injected with
      templatefile) for your environment, or remove the <ip-filter> block
      entirely for a public sandbox where any client IP is allowed.
    -->
    <ip-filter action="allow">
      <address-range from="10.0.0.0" to="10.255.255.255" />
    </ip-filter>
  </inbound>
  <backend><base /></backend>
  <outbound><base /></outbound>
  <on-error><base /></on-error>
</policies>
